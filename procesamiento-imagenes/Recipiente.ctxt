comment4.text=\r\n\ verificar\ que\ el\ recipiente\ est\u00E9\ vacio\r\n\ @return\ true\ si\ est\u00E1\ vacio\r\n\ @return\ false\ si\ contiene\ una\ pieza.\r\n
