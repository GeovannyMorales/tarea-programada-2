comment5.text=\r\n\ verificar\ si\ el\ recipiente\ est\u00E1\ lleno\r\n\ @return\ true,\ si\ el\ recipiente\ llego\ a\ su\ capacidad\ maxima\ de\ piezas\r\n\ @return\ false\ si\ faltan\ piezas\r\n
comment6.params=
